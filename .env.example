# Point at your Laravel API (no trailing slash).
#
# Local Laragon (Android emulator):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
#
# Local Laragon (iOS simulator / Expo web):
# EXPO_PUBLIC_API_URL=http://localhost:8000
#
# Physical phone on same Wi‑Fi (replace with your PC IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
#
# Render production (APK builds use eas.json — see docs/INSTALL-APK.md):
# EXPO_PUBLIC_API_URL=https://diet-elite-w4kw.onrender.com

EXPO_PUBLIC_API_URL=http://localhost:8000
